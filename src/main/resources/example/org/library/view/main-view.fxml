<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="example.org.library.controller.MainController"
            styleClass="root-pane"
            prefWidth="1050" prefHeight="700">

    <!-- Шапка -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="14" styleClass="title-bar">
            <padding>
                <Insets top="16" right="30" bottom="16" left="30"/>
            </padding>
            <Label text="📚 Личная Библиотека" styleClass="header-title"/>
            <Label fx:id="overdueLabel" text="" styleClass="overdue-badge" visible="false" managed="false"/>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>
    </top>

    <!-- Вкладки -->
    <center>
        <TabPane fx:id="mainTabPane" styleClass="main-tabs" tabClosingPolicy="UNAVAILABLE">

            <!-- ========== ВКЛАДКА «КАТАЛОГ» ========== -->
            <Tab text="Каталог">
                <BorderPane styleClass="tab-content">
                    <!-- Фильтры + кнопка добавления -->
                    <top>
                        <VBox spacing="0">
                            <!-- Верхняя строка: кнопка добавить -->
                            <HBox spacing="12" alignment="CENTER_LEFT" styleClass="filter-bar">
                                <padding>
                                    <Insets top="14" right="30" bottom="14" left="30"/>
                                </padding>
                                <ComboBox fx:id="searchStrategyBox" styleClass="filter-combo" prefWidth="140"/>
                                <TextField fx:id="catalogSearchField" promptText="Поиск..."
                                           styleClass="search-field" HBox.hgrow="ALWAYS"/>
                                <ComboBox fx:id="genreFilter" styleClass="filter-combo" prefWidth="200"/>
                                <ComboBox fx:id="statusFilter" styleClass="filter-combo" prefWidth="160"/>
                                <Button text="✕ Сбросить" onAction="#onClearCatalogFilters" styleClass="btn-clear"/>
                            </HBox>
                        </VBox>
                    </top>
                    <center>
                        <VBox styleClass="table-section">
                            <padding>
                                <Insets top="0" right="30" bottom="0" left="30"/>
                            </padding>
                            <TableView fx:id="catalogTable" VBox.vgrow="ALWAYS" styleClass="book-table">
                                <columns>
                                    <TableColumn fx:id="itemTypeColumn" text="Тип" prefWidth="110" minWidth="85"/>
                                    <TableColumn fx:id="itemTitleColumn" text="Название" prefWidth="200" minWidth="140"/>
                                    <TableColumn fx:id="itemAuthorColumn" text="Автор" prefWidth="170" minWidth="110"/>
                                    <TableColumn fx:id="itemGenreColumn" text="Жанр" prefWidth="140" minWidth="90"/>
                                    <TableColumn fx:id="itemYearColumn" text="Год" prefWidth="55" minWidth="50"/>
                                    <TableColumn fx:id="itemDetailsColumn" text="Детали" prefWidth="120" minWidth="80"/>
                                    <TableColumn fx:id="itemStatusColumn" text="Статус" prefWidth="105" minWidth="85"/>
                                </columns>
                                <columnResizePolicy>
                                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                </columnResizePolicy>
                            </TableView>
                        </VBox>
                    </center>
                    <bottom>
                        <HBox spacing="12" alignment="CENTER_RIGHT" styleClass="bottom-bar">
                            <padding>
                                <Insets top="12" right="30" bottom="14" left="30"/>
                            </padding>
                            <Label fx:id="catalogCountLabel" text="0" styleClass="book-count"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button fx:id="addItemButton" text="+ Добавить" onAction="#onAddItem" styleClass="btn-add"/>
                            <Button fx:id="editItemButton" text="Редактировать" onAction="#onEditItem" styleClass="btn-edit"/>
                            <Button fx:id="deleteItemButton" text="Удалить" onAction="#onDeleteItem" styleClass="btn-delete"/>
                        </HBox>
                    </bottom>
                </BorderPane>
            </Tab>

            <!-- ========== ВКЛАДКА «ЧИТАТЕЛИ» ========== -->
            <Tab text="Читатели">
                <BorderPane styleClass="tab-content">
                    <top>
                        <HBox spacing="12" alignment="CENTER_LEFT" styleClass="filter-bar">
                            <padding>
                                <Insets top="14" right="30" bottom="14" left="30"/>
                            </padding>
                            <TextField fx:id="readerSearchField" promptText="Поиск по имени..."
                                       styleClass="search-field" HBox.hgrow="ALWAYS"/>
                        </HBox>
                    </top>
                    <center>
                        <VBox styleClass="table-section">
                            <padding>
                                <Insets top="0" right="30" bottom="0" left="30"/>
                            </padding>
                            <TableView fx:id="readerTable" VBox.vgrow="ALWAYS" styleClass="book-table">
                                <columns>
                                    <TableColumn fx:id="readerNameColumn" text="Имя" prefWidth="220" minWidth="150"/>
                                    <TableColumn fx:id="readerPhoneColumn" text="Телефон" prefWidth="170" minWidth="110"/>
                                    <TableColumn fx:id="readerEmailColumn" text="Email" prefWidth="220" minWidth="130"/>
                                    <TableColumn fx:id="readerLoansColumn" text="Активных выдач" prefWidth="130" minWidth="90"/>
                                </columns>
                                <columnResizePolicy>
                                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                </columnResizePolicy>
                            </TableView>
                        </VBox>
                    </center>
                    <bottom>
                        <HBox spacing="12" alignment="CENTER_RIGHT" styleClass="bottom-bar">
                            <padding>
                                <Insets top="12" right="30" bottom="14" left="30"/>
                            </padding>
                            <Label fx:id="readerCountLabel" text="0" styleClass="book-count"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button fx:id="addReaderButton" text="+ Добавить читателя" onAction="#onAddReader" styleClass="btn-add"/>
                            <Button fx:id="editReaderButton" text="Редактировать" onAction="#onEditReader" styleClass="btn-edit"/>
                            <Button fx:id="deleteReaderButton" text="Удалить" onAction="#onDeleteReader" styleClass="btn-delete"/>
                        </HBox>
                    </bottom>
                </BorderPane>
            </Tab>

            <!-- ========== ВКЛАДКА «ВЫДАЧИ» ========== -->
            <Tab text="Выдачи">
                <BorderPane styleClass="tab-content">
                    <top>
                        <HBox spacing="12" alignment="CENTER_LEFT" styleClass="filter-bar">
                            <padding>
                                <Insets top="14" right="30" bottom="14" left="30"/>
                            </padding>
                            <ComboBox fx:id="loanStatusFilter" styleClass="filter-combo" prefWidth="200"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button fx:id="issueLoanButton" text="+ Выдать книгу" onAction="#onIssueLoan" styleClass="btn-add"/>
                        </HBox>
                    </top>
                    <center>
                        <VBox styleClass="table-section">
                            <padding>
                                <Insets top="0" right="30" bottom="0" left="30"/>
                            </padding>
                            <TableView fx:id="loanTable" VBox.vgrow="ALWAYS" styleClass="book-table">
                                <columns>
                                    <TableColumn fx:id="loanBookColumn" text="Книга" prefWidth="210" minWidth="150"/>
                                    <TableColumn fx:id="loanReaderColumn" text="Читатель" prefWidth="170" minWidth="120"/>
                                    <TableColumn fx:id="loanBorrowDateColumn" text="Выдана" prefWidth="100" minWidth="90"/>
                                    <TableColumn fx:id="loanDueDateColumn" text="Вернуть до" prefWidth="100" minWidth="90"/>
                                    <TableColumn fx:id="loanReturnDateColumn" text="Возвращена" prefWidth="100" minWidth="90"/>
                                    <TableColumn fx:id="loanStatusColumn" text="Статус" prefWidth="100" minWidth="85"/>
                                </columns>
                                <columnResizePolicy>
                                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                </columnResizePolicy>
                            </TableView>
                        </VBox>
                    </center>
                    <bottom>
                        <HBox spacing="12" alignment="CENTER_RIGHT" styleClass="bottom-bar">
                            <padding>
                                <Insets top="12" right="30" bottom="14" left="30"/>
                            </padding>
                            <Label fx:id="loanCountLabel" text="0" styleClass="book-count"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button fx:id="returnLoanButton" text="↩ Вернуть книгу" onAction="#onReturnLoan" styleClass="btn-edit"/>
                        </HBox>
                    </bottom>
                </BorderPane>
            </Tab>

        </TabPane>
    </center>

</BorderPane>
