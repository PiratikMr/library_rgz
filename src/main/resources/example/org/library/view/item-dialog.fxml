<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<DialogPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="example.org.library.controller.ItemDialogController"
            styleClass="dialog-pane"
            prefWidth="520">

    <headerText>Заполните информацию об элементе библиотеки</headerText>

    <content>
        <VBox spacing="14" styleClass="dialog-content">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>

            <!-- Тип элемента -->
            <VBox spacing="4">
                <Label text="Тип элемента" styleClass="field-label"/>
                <ComboBox fx:id="typeBox" styleClass="dialog-combo" maxWidth="Infinity"/>
            </VBox>

            <!-- Название -->
            <VBox spacing="4">
                <Label text="Название *" styleClass="field-label"/>
                <TextField fx:id="titleField" promptText="Введите название"
                           styleClass="dialog-field"/>
            </VBox>

            <!-- Автор: имя и фамилия -->
            <HBox spacing="14">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Имя автора *" styleClass="field-label"/>
                    <TextField fx:id="authorFirstNameField" promptText="Имя"
                               styleClass="dialog-field"/>
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Фамилия автора *" styleClass="field-label"/>
                    <TextField fx:id="authorLastNameField" promptText="Фамилия"
                               styleClass="dialog-field"/>
                </VBox>
            </HBox>

            <!-- Страна автора -->
            <VBox spacing="4">
                <Label text="Страна автора" styleClass="field-label"/>
                <TextField fx:id="authorCountryField" promptText="Страна (необязательно)"
                           styleClass="dialog-field"/>
            </VBox>

            <!-- Жанр и Год -->
            <HBox spacing="14">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Жанр" styleClass="field-label"/>
                    <ComboBox fx:id="genreBox" styleClass="dialog-combo" maxWidth="Infinity"/>
                </VBox>
                <VBox spacing="4" prefWidth="120">
                    <Label text="Год издания *" styleClass="field-label"/>
                    <TextField fx:id="yearField" promptText="Год"
                               styleClass="dialog-field" maxWidth="120"/>
                </VBox>
            </HBox>

            <!-- Поля для печатной книги -->
            <HBox fx:id="printedBookBox" spacing="14">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Количество страниц" styleClass="field-label"/>
                    <TextField fx:id="pageCountField" promptText="0"
                               styleClass="dialog-field"/>
                </VBox>
            </HBox>

            <!-- Поля для аудиокниги -->
            <HBox fx:id="audioBookBox" spacing="14">
                <VBox spacing="4" prefWidth="150">
                    <Label text="Длительность (мин)" styleClass="field-label"/>
                    <TextField fx:id="durationField" promptText="0"
                               styleClass="dialog-field"/>
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Чтец / Озвучка" styleClass="field-label"/>
                    <TextField fx:id="narratorField" promptText="Имя чтеца"
                               styleClass="dialog-field"/>
                </VBox>
            </HBox>

            <!-- Примечания -->
            <VBox spacing="4">
                <Label text="Примечания" styleClass="field-label"/>
                <TextArea fx:id="notesArea" promptText="Дополнительная информация..."
                          styleClass="dialog-textarea" prefRowCount="2" wrapText="true"/>
            </VBox>

            <!-- Ошибка валидации -->
            <Label fx:id="errorLabel" text="" styleClass="error-label"
                   visible="false" managed="false"/>

        </VBox>
    </content>

    <buttonTypes>
        <ButtonType text="Сохранить" buttonData="OK_DONE"/>
        <ButtonType text="Отмена" buttonData="CANCEL_CLOSE"/>
    </buttonTypes>

</DialogPane>
