<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<DialogPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="example.org.library.controller.ReaderDialogController"
            styleClass="dialog-pane"
            prefWidth="440">

    <headerText>Информация о читателе</headerText>

    <content>
        <VBox spacing="14" styleClass="dialog-content">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>

            <HBox spacing="14">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Имя *" styleClass="field-label"/>
                    <TextField fx:id="firstNameField" promptText="Имя"
                               styleClass="dialog-field"/>
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Фамилия *" styleClass="field-label"/>
                    <TextField fx:id="lastNameField" promptText="Фамилия"
                               styleClass="dialog-field"/>
                </VBox>
            </HBox>

            <VBox spacing="4">
                <Label text="Телефон" styleClass="field-label"/>
                <TextField fx:id="phoneField" promptText="+7 (999) 123-45-67"
                           styleClass="dialog-field"/>
            </VBox>

            <VBox spacing="4">
                <Label text="Email" styleClass="field-label"/>
                <TextField fx:id="emailField" promptText="email@example.com"
                           styleClass="dialog-field"/>
            </VBox>

            <Label fx:id="errorLabel" text="" styleClass="error-label"
                   visible="false" managed="false"/>

        </VBox>
    </content>

    <buttonTypes>
        <ButtonType text="Сохранить" buttonData="OK_DONE"/>
        <ButtonType text="Отмена" buttonData="CANCEL_CLOSE"/>
    </buttonTypes>

</DialogPane>
